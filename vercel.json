{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "s-maxage=31536000,immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_PAYPAL_CLIENT_ID": "AXelGwuFcPNmrOaqtvMgsrstOqJL6aNoNEH1m-Uh_0hn_BlSdRw2QFiQ2TV2-Qd8fsPLpTzer1DgGHb2"
  }
}
